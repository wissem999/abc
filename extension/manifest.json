{
  "manifest_version": 3,
  "name": "NetMate - AI for NetAcad",
  "description": "Automatically solve NetAcad quizzes. Click a question to select correct answers. Hover with Ctrl to auto-answer.",
  "version": "4.5",
  "icons": {
    "16": "icon16.svg",
    "48": "icon48.svg",
    "128": "icon128.svg"
  },
  "permissions": [
    "webRequest",
    "storage"
  ],
  "host_permissions": [
    "https://*.netacad.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.netacad.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icon16.svg",
      "48": "icon48.svg",
      "128": "icon128.svg"
    }
  }
}
