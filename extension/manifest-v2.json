{
  "manifest_version": 2,
  "name": "NetMate - AI for NetAcad",
  "description": "Automatically solve NetAcad quizzes. Click a question to select correct answers. Hover with Ctrl to auto-answer.",
  "version": "4.5",
  "icons": {
    "16": "icon16.svg",
    "48": "icon48.svg",
    "128": "icon128.svg"
  },
  "permissions": [
    "webRequest",
    "storage",
    "https://*.netacad.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["https://*.netacad.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icon16.svg",
      "48": "icon48.svg",
      "128": "icon128.svg"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "netmate@netmate.ai",
      "strict_min_version": "91.0"
    }
  }
}
